{
  "name": "n8n-nodes-recruspace",
  "version": "0.1.3",
  "description": "n8n node for Recruspace",
  "license": "MIT",
  "homepage": "https://github.com/Recruspace/n8n-nodes-recruspace#readme",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": {
    "name": "Recruspace",
    "email": "info@recruspace.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Recruspace/n8n-nodes-recruspace.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/RecruspaceApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Recruspace/RecruspaceTrigger.node.js",
      "dist/nodes/Recruspace/Recruspace.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "@types/node": "^25.0.0",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}